generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Doctor {
  id           String               @id @default(cuid())
  name         String
  email        String               @unique
  password     String
  clinicName   String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  /// minutos entre citas
  slotGap      Int                  @default(0)
  appointments Appointment[]
  availability DoctorAvailability[]
  blocks       DoctorBlock[]
  services     Service[]
}

model DoctorAvailability {
  id        String   @id @default(cuid())
  doctorId  String
  day       WeekDay
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
}

model DoctorBlock {
  id        String   @id @default(cuid())
  doctorId  String
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
}

model Service {
  id           String        @id @default(cuid())
  name         String
  description  String?
  duration     Int
  basePrice    Decimal?
  active       Boolean       @default(true)
  doctorId     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  doctor       Doctor        @relation(fields: [doctorId], references: [id])
}

model Patient {
  id           String        @id @default(cuid())
  name         String
  phone        String
  email        String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

model Appointment {
  id              String            @id @default(cuid())
  status          AppointmentStatus @default(PENDING)
  patientId       String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  appointmentDate DateTime
  confirmedAt     DateTime?
  observations    String?
  doctorId        String
  serviceId       String
  doctor          Doctor            @relation(fields: [doctorId], references: [id])
  patient         Patient           @relation(fields: [patientId], references: [id])
  service         Service           @relation(fields: [serviceId], references: [id])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}
